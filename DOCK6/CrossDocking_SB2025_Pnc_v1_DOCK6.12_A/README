bash 001.write_files.sh
bash 002.run.crossdock.sh
bash 003.results.sh
bash 004.sort.lists.sh
bash 005.rerun.results_h.sh
#This generates the heatmaps in Heatmaps folder and calls Make_ploth.py
bash 006.make.heatmaps.sh

